# infra-dashboard configuration
# Copy to .env and fill in values before running any component.

# ── builder-dashboard (Next.js) ──────────────────────────────────────────────
# App branding
NEXT_PUBLIC_APP_NAME="Builder Dashboard"
NEXT_PUBLIC_APP_SHORT_NAME="Builder"
NEXT_PUBLIC_APP_DESCRIPTION="Package builder management dashboard"

# Builder API servers (JSON array). Overrides the compiled-in defaults.
# BUILDER_SERVERS='[{"name":"Primary","description":"Primary Builder","url":"https://builder-api.example.com/api","default":true}]'

# Or set individual URLs:
BUILDER_API_URL_PRIMARY=http://localhost:8080/api
BUILDER_API_URL_SECONDARY=http://localhost:8081/api

# Session cookie encryption key (required, min 32 chars)
COOKIE_SECRET=change-me-to-a-random-32-char-string

# Cloudflare Turnstile site key (set to empty string to disable CAPTCHA in dev)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── public-dashboard (Vite/TanStack) ─────────────────────────────────────────
# App branding
VITE_APP_NAME="Package Dashboard"

# Backend API endpoint
VITE_ENDPOINT_URL=http://localhost:5862/api

# Primary mirror used as sync baseline for mirror health checks
VITE_PRIMARY_MIRROR_URL=http://localhost:5862/repo

# Download URL bases for packages
VITE_CDN_MIRROR_URL=http://localhost:5862
VITE_ARCHLINUX_MIRROR_URL=https://archive.archlinux.org

# GitHub token for fetching PKGBUILD data (optional)
# GITHUB_TOKEN=ghp_...

# Comma-separated "owner/repo" pairs to search for PKGBUILDs.
# First entry is treated as the kernel repo (matched by pkg_name prefix).
# Leave empty to disable PKGBUILD source links.
# PKGBUILD_REPOS=myorg/linux-kernel,myorg/pkgbuilds

# ── statuspage (Upptime) ──────────────────────────────────────────────────────
# Edit statuspage/.upptimerc.yml directly — it is the config file.
# Required: set owner, repo, sites, and status-website fields.
