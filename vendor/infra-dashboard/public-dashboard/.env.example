# Copy to .env.local for local development

# ── App identity ──────────────────────────────────────────────────────────────
VITE_APP_NAME=Infra Dashboard
VITE_APP_DESCRIPTION=Infrastructure dashboard — mirror status, package search, build health.
VITE_APP_VERSION=dev

# ── API backend ───────────────────────────────────────────────────────────────
# Base URL of the backend API (no trailing slash)
VITE_ENDPOINT_URL=http://localhost:5862/api

# ── Mirror health ─────────────────────────────────────────────────────────────
# GitHub repo containing the mirrorlist file
VITE_MIRRORLIST_OWNER=
VITE_MIRRORLIST_REPO=
VITE_MIRRORLIST_PATH=mirrorlist/mirrorlist

# Base URL of the primary mirror (used as baseline for lag calculation)
VITE_PRIMARY_MIRROR_URL=

# Comma-separated arch/repo paths to check on each mirror
# Example: x86_64/core,x86_64/extra
VITE_MIRROR_REPO_PATHS=
