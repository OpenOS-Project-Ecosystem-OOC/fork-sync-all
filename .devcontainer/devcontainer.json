{
  "name": "dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "./features/git-filter-repo": {
      "version": "2.47.0"
    },
    "./features/gitr": {
      "version": "latest"
    },
    "./features/incus": {
      "version": "latest",
      "remote": "",
      "remote_url": ""
    }
  },
  "remoteEnv": {
    "GITLAB_TOKEN": "${localEnv:GITLAB_TOKEN}",
    "INCUS_REMOTE": "${localEnv:INCUS_REMOTE}",
    "INCUS_REMOTE_URL": "${localEnv:INCUS_REMOTE_URL}",
    "INCUS_CLIENT_CERT": "${localEnv:INCUS_CLIENT_CERT}",
    "INCUS_CLIENT_KEY": "${localEnv:INCUS_CLIENT_KEY}"
  },
  "postCreateCommand": "pip install --quiet 'headroom-ai[proxy,mcp]'"
}
