  // ────────────────────────────────────────────────────────────────────────────
  "name": "dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },
  "postCreateCommand": "pip install --quiet 'headroom-ai[proxy,mcp]'",
  "remoteEnv": {}
}
